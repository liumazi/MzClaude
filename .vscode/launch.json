{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "type": "node",
            "request": "launch",
            "name": "agent-gateway",
            "program": "${workspaceFolder}/apps/agent-gateway/dist/src/main.js",            
            "cwd": "${workspaceFolder}/apps/agent-gateway",
            "args": [
                "--port", "39123",
                "--auth-token", "dev-token"
              ],            
            "skipFiles": [
                "<node_internals>/**"
            ],
            "sourceMaps": true,
            "console": "integratedTerminal",
            "preLaunchTask": "build-agent-gateway"
        }
    ]
}