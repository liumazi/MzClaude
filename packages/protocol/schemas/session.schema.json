{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mzclaude.local/schemas/session.schema.json",
  "title": "MzClaude Session",
  "type": "object",
  "required": ["protocolVersion", "id", "workspacePath", "status", "createdAt"],
  "properties": {
    "protocolVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "sdkSessionId": {
      "type": "string"
    },
    "workspacePath": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["idle", "running", "waiting_for_approval", "stopped", "failed"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
