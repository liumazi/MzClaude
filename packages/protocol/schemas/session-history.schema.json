{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mzclaude.local/schemas/session-history.schema.json",
  "title": "MzClaude Session History",
  "type": "object",
  "required": ["protocolVersion", "sessionId", "messages"],
  "properties": {
    "protocolVersion": {
      "type": "integer",
      "const": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "workspacePath": {
      "type": "string"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "uuid", "sessionId", "text"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user", "assistant", "system"]
          },
          "uuid": {
            "type": "string",
            "minLength": 1
          },
          "sessionId": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
